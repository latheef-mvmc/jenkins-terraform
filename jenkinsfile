pipeline {
    agent any 

    environment {
        REPO_URL = "https://github.com/latheef-mvmc/jenkins-terraform.git"
        AWS_REGION = "ap-south-1"
    }

    stages {
        stage('Checkout code') {
            steps {
                echo "Checking out branch: ${env.BRANCH_NAME}"
                git branch: "${env.BRANCH_NAME}", url: "${REPO_URL}"
            }
        }

        stage('Terraform init') {
            steps {
                sh 'terraform init'
            }
        }

        stage('Select workspace') {
            steps {
                script {
                    def ws = env.BRANCH_NAME
                    sh """
                    terraform workspace list | grep ${ws} || terraform workspace new ${ws}
                    terraform workspace select ${ws}
                    """
                }
            }
        }

        stage('Terraform validate') {
            steps {
                sh 'terraform validate'
            }
        }

        stage('Terraform plan') {
            steps {
                sh "terraform plan -var-file=${env.BRANCH_NAME}.tfvars -out=tfplan"
            }
        }

        stage('Terraform apply') {
            when {
                branch 'dev'
                branch 'qa'
                branch 'prod'
            }
            steps {
                sh "terraform apply -var-file=${env.BRANCH_NAME}.tfvars -auto-approve tfplan"
            }
        }
    }
}

